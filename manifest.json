{
  "name": "Re-Redash",
  "version": "1.0",
  "manifest_version": 3,
  "description": "A simple chrome extension that boosts your redash user experience",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": ["https://redash-platform.blinkit.in/*"],
  "content_scripts": [
    {
      "matches": ["https://redash-platform.blinkit.in/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "notebook.js", "notebook.css", "completion-handler.js", "table-column-visibility.js", "table-column-visibility.css"],
      "matches": ["https://redash-platform.blinkit.in/*"]
    }
  ]
}
